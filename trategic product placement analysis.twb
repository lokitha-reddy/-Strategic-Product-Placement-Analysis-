      <aliases enabled='yes' />
      <column caption='Bill_Number' datatype='string' name='[Bill_number]' role='dimension' type='nominal' />
      <column caption='Product_Placement' datatype='string' name='[Calculation_0503049409503232]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Product_category] = &quot;Clothing&quot; THEN &quot;Eye Level Shelf&quot;&#13;&#10;&#13;&#10;ELSEIF [Product_category] = &quot;Shoes&quot; THEN &quot;Window Display&quot;&#13;&#10;&#13;&#10;ELSEIF [Product_category] = &quot;Cosmetics&quot; THEN &quot;Checkout Area&quot;&#13;&#10;&#13;&#10;ELSEIF [Product_category] = &quot;Food &amp; Beverage&quot; THEN &quot;Aisle Display&quot;&#13;&#10;&#13;&#10;ELSEIF [Product_category] = &quot;Technology&quot; THEN &quot;End Cap Display&quot;&#13;&#10;&#13;&#10;ELSE &quot;Regular Shelf&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Sales_Amount' datatype='real' default-format='c&quot;₺&quot;#,##0.00' name='[Calculation_0503049409961985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity_purchased] * [Product_price]' />
      </column>
      <column caption='Average Sales' datatype='real' name='[Calculation_0503049601236994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0503049409961985]) / COUNTD([Bill_number])' />
      </column>
      <column caption='Payment_Type' datatype='string' name='[Payment_type]' role='dimension' type='nominal' />
      <column datatype='string' name='[Product_Placement (group)]' role='dimension' type='nominal'>
        <calculation class='categorical-bin' column='[Calculation_0503049409503232]' new-bin='true'>
          <bin default-name='true' value='&quot;Aisle Display, Checkout Area, End Cap Display and 3 more&quot;'>
            <value>&quot;Aisle Display&quot;</value>
            <value>&quot;Checkout Area&quot;</value>
            <value>&quot;End Cap Display&quot;</value>
            <value>&quot;Eye Level Shelf&quot;</value>
            <value>&quot;Regular Shelf&quot;</value>
            <value>&quot;Window Display&quot;</value>
          </bin>
        </calculation>
      </column>
      <column caption='Product_Category' datatype='string' name='[Product_category]' role='dimension' type='nominal' />
      <column caption='Product_Price' datatype='real' default-format='c&quot;₺&quot;#,##0.00;&quot;₺&quot;-#,##0.00' name='[Product_price]' role='measure' type='quantitative' />
      <column caption='Purchase_Date' datatype='date' name='[Purchase_date]' role='dimension' type='ordinal' />
